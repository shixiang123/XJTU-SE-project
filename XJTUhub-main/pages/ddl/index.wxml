<view class="theme-{{themeMode}}">
  <cu-custom bgColor="bg-nav-theme" isBack="{{true}}">
    <view slot="backText">返回</view>
    <view slot="content">DDL提醒</view>
  </cu-custom>

  <view class="container ios-page {{pageReady ? 'is-ready' : ''}}">
    <view class="tips card-shell">支持勾选完成状态；展示作业名称、课程名称、截止时间。</view>

    <button class="cu-btn sync-btn ios-btn" loading="{{loadingRemote}}" bindtap="pullSyxtDdl">从 LMS 拉取 DDL</button>

    <view class="list">
      <view class="item card-shell ios-tap {{item.done ? 'done' : ''}}" wx:for="{{list}}" wx:key="id">
        <view class="header-row">
          <switch class="theme" checked="{{item.done}}" data-id="{{item.id}}" bindchange="toggleDone" />
        </view>
        <view class="meta-line strong-line {{item.done ? 'done-line' : ''}}">
          <text class="meta-label">作业名称：</text>
          <text class="meta-value">{{item.title}}</text>
        </view>
        <view class="meta-line strong-line {{item.done ? 'done-line' : ''}}">
          <text class="meta-label">课程名称：</text>
          <text class="meta-value">{{item.course}}</text>
        </view>
        <view class="meta-line strong-line {{item.done ? 'done-line' : ''}}">
          <text class="meta-label">截止时间：</text>
          <text class="meta-value">{{item.deadline}}</text>
        </view>
      </view>
    </view>

    <button class="cu-btn reset-btn ios-btn" bindtap="resetDemoData">重置演示数据</button>
  </view>
</view>
