page {
  background: var(--bg-page);
}

.container {
  padding: 24rpx;
}

.card-shell {
  border-radius: 16rpx;
  border: 1rpx solid var(--border-color);
  background: var(--bg-card);
  box-shadow: 0 12rpx 26rpx -22rpx var(--shadow-color);
}

.tips {
  padding: 20rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.list {
  margin-top: 20rpx;
}

.sync-btn {
  margin-top: 16rpx;
  width: 100%;
  height: 86rpx;
  border-radius: 14rpx;
  background: #0f766e;
  color: #ffffff;
}

.item {
  margin-bottom: 18rpx;
  padding: 22rpx;
}

.item.done {
  opacity: 0.72;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-bottom: 8rpx;
}

.meta-line {
  margin-top: 10rpx;
  line-height: 1.7;
}

.meta-line:first-of-type {
  margin-top: 0;
}

.strong-line .meta-label,
.strong-line .meta-value {
  font-size: 30rpx;
  font-weight: 700;
}

.done-line .meta-label,
.done-line .meta-value {
  text-decoration: line-through;
}

.meta-label {
  color: var(--text-secondary);
}

.meta-value {
  color: var(--text-primary);
}

.reset-btn {
  margin-top: 14rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 14rpx;
  background: var(--theme);
  color: #ffffff;
}
