page {
  background: var(--bg-page);
}

.container {
  padding: 24rpx;
}

.card-shell {
  border-radius: 16rpx;
  border: 1rpx solid var(--border-color);
  background: var(--bg-card);
  box-shadow: 0 12rpx 26rpx -22rpx var(--shadow-color);
}

.tips {
  padding: 20rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.loading-tip {
  margin-bottom: 14rpx;
  padding: 16rpx 20rpx;
  color: var(--theme);
  font-size: 24rpx;
  font-weight: 600;
}

.header {
  margin-bottom: 14rpx;
  padding: 10rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.update-btn {
  width: 84rpx;
  height: 84rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--theme);
  font-size: 34rpx;
  background: var(--surface-soft);
}

.update-btn.is-loading {
  opacity: 0.6;
}

.summary {
  margin-top: 18rpx;
  padding: 22rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-head {
  margin-bottom: 14rpx;
}

.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.summary-rate {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-cell {
  padding: 14rpx 10rpx;
  border-radius: 12rpx;
  background: var(--surface-soft);
  border: 1rpx solid var(--border-color);
  text-align: center;
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.summary-value {
  margin-top: 4rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.summary-value.danger {
  color: #dc2626;
}

.summary-time {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.tabs {
  margin-top: 16rpx;
  padding: 8rpx;
  display: flex;
  gap: 8rpx;
}

.tab {
  flex: 1;
  text-align: center;
  border-radius: 10rpx;
  padding: 14rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: transparent;
}

.tab.active {
  color: #ffffff;
  background: var(--theme);
  font-weight: 600;
}

.list {
  margin-top: 20rpx;
}

.item {
  margin-bottom: 18rpx;
  padding: 22rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.risk {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.risk.normal {
  color: #1d4ed8;
  background: rgba(59, 130, 246, 0.16);
}

.risk.warning {
  color: #c98613;
  background: rgba(245, 158, 11, 0.18);
}

.risk.danger {
  color: #f87171;
  background: rgba(239, 68, 68, 0.16);
}

.meta {
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.stats-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  row-gap: 8rpx;
  column-gap: 20rpx;
  color: var(--text-primary);
  font-size: 24rpx;
}

.rate {
  font-weight: 600;
}

.empty {
  margin-top: 20rpx;
  padding: 26rpx 20rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.sync-btn {
  margin-top: 14rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 14rpx;
  background: var(--theme);
  color: #ffffff;
}
